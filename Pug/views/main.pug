doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")

        title= title

        link(rel="stylesheet", href="/style.css")

body
    main 
        h1= title

        p This page shows all users stored on the server.

        if users.length > 0
            table
                thead
                    tr
                        th First name
                        th Last name
                        th Age
                        th Action

                tbody
                    each user in users
                        tr
                            td= `${user.getFirstName()}`
                            td= `${user.getLastName()}`
                            td= `${user.getAge()}`

                            td
                                form(
                                    action=`/users/delete/${user.getId()}`
                                    method="post"
                                    onsubmit="return confirm('Are you sure you want to delete this user?')"
                                )
                                    button(type="submit") Delete
        else
            p.empty-message There are no users left.